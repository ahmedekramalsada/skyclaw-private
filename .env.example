# batabeto — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# USAGE:
#   cp .env.example /root/.skyclaw/.env
#   nano /root/.skyclaw/.env       ← fill in your values
#   chmod 600 /root/.skyclaw/.env  ← secrets readable by root only
#
# The systemd service loads this file automatically via EnvironmentFile.
# You can also export these in your shell for local testing.
# ─────────────────────────────────────────────────────────────────────────────


# ── REQUIRED — batabeto will not start without these ─────────────────────────

# Telegram bot token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# OpenRouter API key — get from https://openrouter.ai/keys
# Format: sk-or-v1-...
OPENROUTER_API_KEY=sk-or-v1-your-key-here


# ── KUBERNETES / K3S ─────────────────────────────────────────────────────────

# K3s single-node (default path)
KUBECONFIG=/etc/rancher/k3s/k3s.yaml

# Multi-cluster: point to merged kubeconfig
# KUBECONFIG=/root/.kube/config


# ── SSH ───────────────────────────────────────────────────────────────────────

# Dedicated SSH key for batabeto to reach remote servers
# Generate with: ssh-keygen -t ed25519 -C "batabeto" -f /root/.ssh/batabeto -N ""
# Then copy to remote servers: ssh-copy-id -i /root/.ssh/batabeto.pub root@server1
SSH_KEY_PATH=/root/.ssh/batabeto


# ── TERRAFORM ─────────────────────────────────────────────────────────────────

# Root directory where your terraform workspaces live
TERRAFORM_ROOT=/opt/terraform

# Cloud provider credentials — uncomment whichever you use

# AWS
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_DEFAULT_REGION=us-east-1

# Hetzner Cloud
# HCLOUD_TOKEN=your-hetzner-token

# DigitalOcean
# DIGITALOCEAN_TOKEN=your-do-token

# Cloudflare
# CLOUDFLARE_API_TOKEN=your-cf-token
# CLOUDFLARE_ACCOUNT_ID=your-account-id


# ── ANSIBLE ───────────────────────────────────────────────────────────────────

# Ansible inventory file path
ANSIBLE_INVENTORY=/opt/ansible/inventory.yml

# Ansible playbooks directory
ANSIBLE_PLAYBOOKS_DIR=/opt/ansible/playbooks

# Disable host key checking for automated runs
ANSIBLE_HOST_KEY_CHECKING=False

# SSH private key for Ansible connections
ANSIBLE_PRIVATE_KEY_FILE=/root/.ssh/batabeto


# ── DOCKER ────────────────────────────────────────────────────────────────────

# Docker socket — default location, change if custom
DOCKER_HOST=unix:///var/run/docker.sock


# ── MONITORING ────────────────────────────────────────────────────────────────

# Grafana (if you run it)
# GRAFANA_URL=http://localhost:3000
# GRAFANA_API_KEY=your-grafana-api-key

# Prometheus (if you run it)
# PROMETHEUS_URL=http://localhost:9090


# ── SELF-BACKUP — GitHub private repo ────────────────────────────────────────
# batabeto backs itself up every 15 min to a private GitHub repo.
# On fresh install it restores from this repo automatically.
#
# Setup:
#   1. Create a private repo on GitHub (e.g. "batabeto-backup")
#   2. Generate a PAT with "repo" scope: github.com/settings/tokens
#   3. Fill in the three vars below

# Your GitHub username
GITHUB_USERNAME=your-github-username

# Private repo name (must exist on GitHub, can be empty — install.sh will init it)
GITHUB_BACKUP_REPO=batabeto-backup

# GitHub PAT with repo read+write scope
GITHUB_TOKEN=ghp_your-token-here



# ── LOGGING ───────────────────────────────────────────────────────────────────

# Log level: error | warn | info | debug | trace
RUST_LOG=info

# Set to 1 for full backtraces on panic (useful during setup)
RUST_BACKTRACE=0
